{
  "name": "backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "typeorm": "typeorm-ts-node-commonjs",
    "typeorm-extension": "ts-node ./node_modules/typeorm-extension/bin/cli.cjs",
    "migration:create": "npm run typeorm migration:create src/@infra/database/migrations/migration-create.migration",
    "migration:run-dev": "npm run typeorm migration:run -- -d src/@infra/database/datasource",
    "migration:run": "npm run typeorm migration:run -- -d dist/@infra/database/datasource",
    "seed:run": "npm run typeorm-extension seed:run -- -d src/@infra/database/datasource"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1053.0",
    "@aws-sdk/lib-storage": "^3.1053.0",
    "@aws-sdk/s3-request-presigner": "^3.1053.0",
    "@jest/types": "^30.4.1",
    "@nestjs/common": "^11.0.1",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/platform-socket.io": "^11.1.24",
    "@nestjs/typeorm": "^11.0.1",
    "@swc/jest": "^0.2.39",
    "@types/amqplib": "^0.10.8",
    "@types/jest": "^30.0.0",
    "@vonage/messages": "^1.24.0",
    "@vonage/server-sdk": "^3.27.0",
    "amqplib": "^2.0.1",
    "axios": "^1.16.1",
    "bcryptjs": "^3.0.3",
    "jest": "^30.4.2",
    "jsonwebtoken": "^9.0.3",
    "moment": "^2.30.1",
    "moment-timezone": "^0.6.2",
    "nodemailer": "^8.0.10",
    "pg": "^8.20.0",
    "redis": "^5.12.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sinon": "^22.0.0",
    "ts-jest": "^29.2.5",
    "typeorm": "^0.3.29",
    "typeorm-extension": "^3.9.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@swc/core": "^1.15.33",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.0.0",
    "@types/sinon": "^21.0.1",
    "@types/supertest": "^7.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  }
}
